{
  "apiTitle": "Certazy Backend API",
  "version": "1.0.0",
  "description": "Online Learning & Certification System API Documentation",
  "baseUrl": "http://localhost:5000/api",
  "modules": {
    "auth": {
      "name": "Authentication",
      "description": "User authentication and authorization endpoints",
      "endpoints": [
        {
          "method": "POST",
          "endpoint": "/api/auth/register",
          "description": "Student registration with email verification",
          "authRequired": false,
          "roleRequired": "public",
          "requestBody": {
            "name": { "type": "string", "required": true, "minLength": 2, "maxLength": 100 },
            "email": { "type": "string", "required": true, "format": "email", "maxLength": 150 },
            "password": { "type": "string", "required": true, "minLength": 8, "maxLength": 72, "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])" }
          },
          "response": {
            "success": true,
            "message": "Registration successful",
            "data": {
              "user": {
                "id": 1,
                "name": "John Doe",
                "email": "john@example.com",
                "role": "student",
                "is_verified": false,
                "is_active": true,
                "created_at": "2024-01-01T00:00:00.000Z"
              }
            }
          }
        },
        {
          "method": "POST",
          "endpoint": "/api/auth/login",
          "description": "Login for all user roles",
          "authRequired": false,
          "roleRequired": "public",
          "requestBody": {
            "email": { "type": "string", "required": true, "format": "email" },
            "password": { "type": "string", "required": true }
          },
          "response": {
            "success": true,
            "message": "Login successful",
            "data": {
              "user": {
                "id": 1,
                "name": "John Doe",
                "email": "john@example.com",
                "role": "student"
              },
              "isFirstLogin": false
            }
          }
        },
        {
          "method": "POST",
          "endpoint": "/api/auth/refresh",
          "description": "Refresh access token using refresh token",
          "authRequired": false,
          "roleRequired": "public",
          "requestBody": {},
          "response": {
            "success": true,
            "message": "Token refreshed"
          }
        },
        {
          "method": "POST",
          "endpoint": "/api/auth/logout",
          "description": "Logout user and clear tokens",
          "authRequired": false,
          "roleRequired": "public",
          "requestBody": {},
          "response": {
            "success": true,
            "message": "Logged out successfully"
          }
        },
        {
          "method": "POST",
          "endpoint": "/api/auth/change-password",
          "description": "Change password (first login or regular)",
          "authRequired": true,
          "roleRequired": "student/sub_admin/admin",
          "requestBody": {
            "currentPassword": { "type": "string", "required": true },
            "newPassword": { "type": "string", "required": true, "minLength": 8, "maxLength": 72, "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])" }
          },
          "response": {
            "success": true,
            "message": "Password changed successfully. Please login again."
          }
        },
        {
          "method": "GET",
          "endpoint": "/api/auth/me",
          "description": "Get current user profile",
          "authRequired": true,
          "roleRequired": "student/sub_admin/admin",
          "requestBody": {},
          "response": {
            "success": true,
            "message": "User fetched",
            "data": {
              "user": {
                "id": 1,
                "name": "John Doe",
                "email": "john@example.com",
                "role": "student",
                "avatar": "https://example.com/avatar.jpg",
                "is_verified": true,
                "is_active": true
              }
            }
          }
        }
      ]
    },
